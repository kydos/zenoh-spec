{
  "name": "zenoh-spec",
  "version": "2.0.0",
  "description": "Zenoh v2.0.0 Protocol Specification",
  "private": true,
  "scripts": {
    "build": "antora antora-playbook.yml",
    "build:local": "antora antora-playbook-local.yml",
    "serve": "npx http-server build/site -p 3000 -c-1",
    "stop": "lsof -ti :3000 | xargs kill 2>/dev/null || true",
    "dev": "npm run stop && antora antora-playbook-local.yml && npx http-server build/site -p 3000 -c-1"
  },
  "devDependencies": {
    "@antora/cli": "^3.1",
    "@antora/site-generator": "^3.1"
  }
}
